# Optional: configure any OpenAI-compatible chat-completions provider.
# Without these values, StadiumPulse runs with a labeled local demo AI fallback.
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=https://api.openai.com/v1

# Groq option. If GROQ_API_KEY is set, these Groq defaults are used automatically.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Required for public deployments. Users enter this access code to unlock AI features.
APP_ACCESS_TOKEN=
APP_ALLOWED_ORIGINS=

# Production resource controls.
AI_CONCURRENCY_MAX=4
AI_QUEUE_MAX=24
AI_QUEUE_TIMEOUT_MS=5000
AI_TIMEOUT_MS=20000
BRIEFING_CACHE_TTL_MS=30000
BRIEFING_CACHE_MAX_ENTRIES=32
RATE_LIMIT_MAX_BUCKETS=5000
CUSTOM_SCENARIO_FILE=./data/custom-scenarios.json

# Optional server port.
PORT=4173
